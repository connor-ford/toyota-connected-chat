# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# API Gateway endpoint for Lex Lambda
REACT_APP_LEX_API_URL=https://XXXXXXXX.execute-api.REGION.amazonaws.com/prod/chat

# API Gateway endpoint for Connect escalation Lambda
REACT_APP_CONNECT_API_URL=https://XXXXXXXX.execute-api.REGION.amazonaws.com/prod/escalate

# API key (set in API Gateway, passed as x-api-key header)
REACT_APP_API_KEY=your-api-key-here

# Your Connect instance region (e.g. ap-southeast-2)
REACT_APP_AWS_REGION=us-east-1
